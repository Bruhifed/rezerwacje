<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Rezerwacje" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <style>
      .logout_guzik{
          padding: 0px 8px;
          margin-left: 10px;
      }
  </style>

  <body>
  <nav>
    <% if current_user %>
      <% if current_user.admin? %>
        <%= link_to 'Strona główna', root_path %> |
        <%= link_to 'Zarządzaj pokojami', admin_rooms_path %> |
        <%= link_to 'Zarządzaj sprzętem', admin_room_equipments_path %> |
        <%= button_to "Wyloguj", logout_path, method: :delete, class: "logout-button", form: { data: { turbo: false } } %>
      <% else %>
        <%= link_to 'Strona główna', root_path %> |
        <%= link_to 'Moje rezerwacje', bookings_path %> |
        <%= button_to "Wyloguj", logout_path, method: :delete, class: "logout-button", form: { data: { turbo: false } } %>
      <% end %>
    <% else %>
      <%= link_to 'Strona główna', root_path %> |
      <%= link_to 'Zaloguj', login_path %> |
      <%= link_to 'Rejestracja', register_path %>
    <% end %>
  </nav>
    <%= yield %>
  </body>
</html>
