<style>
    .container {
        padding: 20px;
    }
    .login{
        div{
            display: flex;
            flex-direction: column;
        }
        form{
            display: flex;
            flex-direction: column;
            label{
                padding: 5px 0px 5px 0px;
            }
            input[type=submit]{
                margin-top: 10px;
                padding: 10px;
                border: 1px solid dodgerblue;
                border-radius: 5px;
            }
        }
        height: fit-content;
        width: fit-content;
        padding: 15px;
        border: 1px solid black;
        border-radius: 15px;
    }
</style>
<div class="container">
  <h1>Logowanie</h1>
  <div class="login">
    <%= form_with url: login_path do |f| %>
      <div>
        <%= f.label :email %>
        <%= f.email_field :email, required: true %>
      </div>
      <div>
        <%= f.label :password, "Hasło" %>
        <%= f.password_field :password, required: true %>
      </div>
      <%= f.submit 'Login' %>
    <% end %>
  </div>
</div>